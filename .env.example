GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# LLM Model Routing (OpenRouter — plain model names, api_base set in gateway/router.py)
CHEAP_MODEL=google/gemini-2.0-flash-001
STRONG_MODEL=google/gemini-2.0-flash-001

# Storage
CHROMA_PERSIST_PATH=./chroma_db
DATABASE_URL=sqlite:///./halcyon_decisions.db

# Pipeline tuning
FAITHFULNESS_THRESHOLD=0.75
MAX_RETRIES=2
COST_CEILING_USD=0.10

# Logging
LOG_LEVEL=INFO
