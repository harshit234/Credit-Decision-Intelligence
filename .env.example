# ──────────────────────────────────────────────────────────────────────────
# Halcyon Credit — environment configuration
# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
# ──────────────────────────────────────────────────────────────────────────

# ---- LLM gateway (LiteLLM) ----
LITELLM_API_KEY_GEMINI=          # cheap path: Gemini Flash (income/credit/policy agents)
LITELLM_API_KEY_OPENAI=          # fallback / strong path (synthesizer + judge)
LITELLM_MASTER_KEY=              # optional: LiteLLM proxy master key

# ---- Policy vector store (ChromaDB) ----
CHROMA_PERSIST_PATH=./chroma     # local dev path for the policy collection

# ---- Persistence (decision records) ----
DATABASE_URL=sqlite:///./halcyon.sqlite   # dev; use postgres://... in deployment

# ---- Pipeline thresholds ----
FAITHFULNESS_THRESHOLD=0.75      # Evaluation Agent pass bar
MAX_RETRIES=2                    # synthesizer↔evaluator loop cap before human escalation
COST_CEILING_USD=0.10            # per-application cost alarm threshold

# ---- Observability ----
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
